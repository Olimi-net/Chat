<UserControl x:Class="ChatClient.View.LoginControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <UserControl.Resources>
        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="10px" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="10px" />
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition MinWidth="200" MaxWidth="400"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Grid.Column="1" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label Content="{Binding LastError}"/>
            
            <TabControl Grid.Row="1">
                <TabItem>
                    <TabItem.Header>
                        <Label Content="Вход"/>
                    </TabItem.Header>
                    <TabItem.Content>
                        <Grid Margin="10px">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Content="Логин"
                               VerticalAlignment="Center"
                               Margin="10px,10px, 10px, 0px"/>

                            <TextBox Grid.Row="1" Text="{Binding Path=UserLogin}"
                                 Margin="10px,0px, 10px, 10px"
                                 Padding="4px"
                                 HorizontalAlignment="Stretch"/>

                            <Label Grid.Row="2"
                               VerticalAlignment="Center"
                               Margin="10px,10px, 10px, 0px"
                               Content="Пароль"/>
                            <PasswordBox Grid.Row="3"
                                     Name="UserPassword"
                                     Padding="4px"
                                     Margin="10px,0px, 10px, 10px"
                                     HorizontalAlignment="Stretch">
                            </PasswordBox>

                            <Button Command="{Binding CheckIn}"
                                CommandParameter="{Binding ElementName=UserPassword}"
                                Grid.Row="4" 
                                Padding="4px"
                                Content="Войти"/>
                        </Grid>
                    </TabItem.Content>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <Label Content="Регистрация"/>
                    </TabItem.Header>
                    <TabItem.Content>
                        <Grid Margin="10px">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Content="Логин"
                               Margin="10px,10px, 10px, 0px"
                               VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" 
                                 Text="{Binding Path=NewLogin}"
                                 Margin="10px,0px, 10px, 10px"
                                 Padding="4px"
                                 HorizontalAlignment="Stretch"/>

                            <Label Content="Пароль" 
                               Margin="10px,10px, 10px, 0px"
                               Grid.Row="2"/>
                            <PasswordBox Grid.Row="3" 
                                     Padding="4px"
                                     Name="NewPassword"
                                     Margin="10px,0px, 10px, 10px"
                                     HorizontalAlignment="Stretch">
                            </PasswordBox>

                            <Button Command="{Binding Invite}" 
                                CommandParameter="{Binding ElementName=NewPassword}"
                                Grid.Row="4" 
                                Padding="4px"
                                Content="Регистрация"/>
                        </Grid>
                    </TabItem.Content>
                </TabItem>


            </TabControl>

        </Grid>
        
        
    </Grid>
</UserControl>
